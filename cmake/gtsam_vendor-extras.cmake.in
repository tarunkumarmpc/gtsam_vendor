include(CMakeFindDependencyMacro)

# Find GTSAM
# The GTSAMConfig.cmake is installed into the same prefix as gtsam_vendor.
# We help CMake find it by providing the relative path to the install prefix.
set(_gtsam_vendor_prefix "${CMAKE_CURRENT_LIST_DIR}/../../..")

# Check both uppercase and lowercase variants just in case
if(EXISTS "${_gtsam_vendor_prefix}/lib/cmake/GTSAM/GTSAMConfig.cmake")
  find_package(GTSAM CONFIG REQUIRED PATHS "${_gtsam_vendor_prefix}" NO_DEFAULT_PATH)
elseif(EXISTS "${_gtsam_vendor_prefix}/lib/cmake/gtsam/gtsamConfig.cmake")
  find_package(gtsam CONFIG REQUIRED PATHS "${_gtsam_vendor_prefix}" NO_DEFAULT_PATH)
else()
  # Fallback to standard search if not found in the expected relative location
  find_dependency(GTSAM CONFIG REQUIRED)
endif()

unset(_gtsam_vendor_prefix)
